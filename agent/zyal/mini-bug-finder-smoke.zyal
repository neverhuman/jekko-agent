# zyalc: mini-fleet smoke test runbook

# Mini fleet smoke test for deterministic bug detection
#
# Engineered fail then fix workflow:
# - first pass: `sum` is implemented as subtraction, test fails
# - second pass after one-line fix: test passes

<<<ZYAL v1:daemon id=mini-fleet-bug-finder-smoke>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Mini fleet smoke bug finder"
  objective: |
    Validate that headless/ZYAL execution catches an engineered failing test quickly
    and that fixing the bug changes run outcome.

context:
  strategy: hard
  compact_every: 2
  hard_clear_every: 4
  preserve:
    - objective

loop:
  policy: once
  sleep: 2s
  continue_on: [assistant_stop, max_steps]

stop:
  all:
    - shell:
        command: "git status --short"

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "cargo test --workspace --locked --no-fail-fast"
      timeout: 20s
      assert: { exit_code: 0 }
  git:
    add: ["."]
    commit_message: "fix: mini fleet smoke"
    push: ask

hooks:
  after_checkpoint:
    - run: "echo mini-bug-finder-smoke after_checkpoint reached"
      timeout: 5s
      on_fail: pause
  on_start:
    - run: "cargo --version"
      timeout: 10s
      on_fail: pause

permissions:
  shell: allow
  edit: allow
  git_push: ask
  git_commit: allow

ui:
  banner: forever
<<<END_ZYAL id=mini-fleet-bug-finder-smoke>>>
ZYAL_ARM RUN_FOREVER id=mini-fleet-bug-finder-smoke
