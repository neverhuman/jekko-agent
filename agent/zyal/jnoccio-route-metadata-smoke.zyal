# zyalc: jnoccio route-metadata smoke

<<<ZYAL v1:daemon id=jnoccio-route-metadata-smoke>>>
version: v1
intent: daemon
confirm: RUN_FOREVER

job:
  name: "Jnoccio route-metadata smoke"
  objective: |
    Validate that route metadata smoke fixtures stay parseable and deterministic.
  risk:
    - Keep this fixture intentionally lightweight and bounded.

context:
  strategy: hard
  compact_every: 2
  hard_clear_every: 4
  preserve:
    - objective

loop:
  policy: once
  sleep: 2s
  continue_on: [assistant_stop, max_steps]

stop:
  all:
    - shell:
        command: "echo jnoccio-route-metadata-smoke complete"
        timeout: 5s
        assert: { exit_code: 0 }

fan_out:
  strategy: scatter_gather
  split:
    shell: "echo split"
  worker:
    agent: build
    isolation: same_session
    timeout: 2m
    max_parallel: 1
  reduce:
    strategy: custom_shell
    command: "cargo test -p jekko-runtime --locked --no-fail-fast"

hooks:
  on_start:
    - run: "cargo --version"
      timeout: 10s
      on_fail: pause

permissions:
  shell: allow
  edit: allow

ui:
  banner: forever

checkpoint:
  when: after_verified_change
  noop_if_clean: true
  verify:
    - command: "cargo test -p jekko-runtime --locked --no-fail-fast"
      timeout: 20s
      assert: { exit_code: 0 }
  git:
    add: ["."]
    commit_message: "fix: jnoccio route-metadata smoke"
    push: ask
<<<END_ZYAL id=jnoccio-route-metadata-smoke>>>
ZYAL_ARM RUN_FOREVER id=jnoccio-route-metadata-smoke
